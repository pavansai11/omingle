NEXT_PUBLIC_BASE_URL=https://hippichat.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
REDIS_URL=rediss://default:password@your-upstash-tcp-endpoint:6379
UPSTASH_REDIS_REST_URL=https://your-upstash-rest-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Preferred: use a full MongoDB Atlas URI
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/HippiChat?retryWrites=true&w=majority

# Optional fallback fields if you don't use MONGODB_URI
MONGO_USERNAME=hippichat
MONGO_PASSWORD=replace_me
MONGO_HOST=cluster0.example.mongodb.net/?retryWrites=true&w=majority&appName=HippiChat
DB_NAME=HippiChat

CORS_ORIGINS=https://hippichat.com,https://www.hippichat.com,http://localhost:3000,http://127.0.0.1:3000
COTURN_STATIC_AUTH_SECRET=replace_with_coturn_shared_secret
TURN_HOST=turn.hippichat.com
TURN_PORT=3478
TURN_CREDENTIAL_TTL_SECONDS=3600

# Cloud Run sets PORT automatically (usually 8080)
HOST=0.0.0.0
PORT=8080
